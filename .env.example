# Mascope / Karsa server credentials.
#
# Copy this file to ~/.mascope/.env and fill in your values:
#     mkdir -p ~/.mascope && cp .env.example ~/.mascope/.env
#
# The pipeline searches ~/.mascope/.env first (then ~/mascope-mcp/.env as a
# fallback). You can point at a different file with the --env flag or the
# MASCOPE_ENV environment variable. Process environment variables of the same
# name also work and take effect without any file.
#
# Your access token comes from the Mascope web app (account / API settings).

MASCOPE_URL=
MASCOPE_ACCESS_TOKEN=
